{
  "name": "@unlikeotherai/unloved",
  "version": "0.2.0",
  "description": "Local multi-device AI coding cockpit",
  "type": "module",
  "bin": {
    "unloved": "./dist/index.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "prebuild": "pnpm --filter @unloved/web build && rm -rf public && cp -r ../web/dist public",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@unloved/server": "workspace:*",
    "@unloved/shared": "workspace:*",
    "tsup": "^8.5.0"
  }
}
